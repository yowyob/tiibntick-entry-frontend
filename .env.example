# =============================================================================
# TiiBnTick Landing — Hub central de l'écosystème
# Copier vers .env.local pour le développement local.
# Toutes les URLs NEXT_PUBLIC_* sont exposées au navigateur.
# =============================================================================

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://tiibntick.yowyob.com

# Thème saisonnier : "noel" | "" (vide = désactivé)
NEXT_PUBLIC_SEASONAL_THEME=

# ── Actions globales ──────────────────────────────────────────────────────────
NEXT_PUBLIC_TRACKING_URL=https://tiibntick-agency.yowyob.com/track
NEXT_PUBLIC_SEND_PARCEL_URL=https://tiibntick-agency.yowyob.com/track/deposit

# ── TiiBnTick Link ────────────────────────────────────────────────────────────
NEXT_PUBLIC_LINK_LANDING_URL=https://tiibntick-link.yowyob.com
NEXT_PUBLIC_LINK_REGISTER_URL=https://tiibntick-link.yowyob.com/register
NEXT_PUBLIC_LINK_LOGIN_URL=https://tiibntick-link.yowyob.com/login

# ── TiiBnTick Go (+ Freelancer = même plateforme) ─────────────────────────────
NEXT_PUBLIC_GO_LANDING_URL=https://tiibntick-go.yowyob.com
NEXT_PUBLIC_GO_REGISTER_URL=https://tiibntick-go.yowyob.com/register
NEXT_PUBLIC_GO_LOGIN_URL=https://tiibntick-go.yowyob.com/login

# ── TiiBnTick Agency ──────────────────────────────────────────────────────────
