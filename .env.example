# =============================================================================
# TiiBnTick Landing — Hub central de l'écosystème
# Copier vers .env.local pour le développement local.
# Toutes les URLs NEXT_PUBLIC_* sont exposées au navigateur.
# =============================================================================

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Thème saisonnier : "noel" | "" (vide = désactivé)
NEXT_PUBLIC_SEASONAL_THEME=noel

# ── Actions globales ──────────────────────────────────────────────────────────
NEXT_PUBLIC_TRACKING_URL=https://track.tiibntick.cm
NEXT_PUBLIC_SEND_PARCEL_URL=https://link.tiibntick.cm/envoyer

# ── TiiBnTick Link ────────────────────────────────────────────────────────────
NEXT_PUBLIC_LINK_LANDING_URL=http://localhost:3002
NEXT_PUBLIC_LINK_REGISTER_URL=http://localhost:3002/register
NEXT_PUBLIC_LINK_LOGIN_URL=http://localhost:3002/login

# ── TiiBnTick Go ──────────────────────────────────────────────────────────────
