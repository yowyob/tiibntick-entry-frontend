NEXT_PUBLIC_POINT_REGISTER_URL=https://tiibntick-point.yowyob.com/register
NEXT_PUBLIC_POINT_LOGIN_URL=https://tiibntick-point.yowyob.com/login

# ── TiiBnTick Freelancer (= Go) ───────────────────────────────────────────────
NEXT_PUBLIC_FREELANCER_LANDING_URL=https://tiibntick-go.yowyob.com
NEXT_PUBLIC_FREELANCER_REGISTER_URL=https://tiibntick-go.yowyob.com/register
